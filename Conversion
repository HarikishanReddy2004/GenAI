import copy

def set_value(data, keys, value):
    current = data

    for i, key in enumerate(keys):

        # ARRAY CASE
        if '#' in key:
            key, idx = key.split('#')
            idx = int(idx) - 1

            if key not in current:
                return

            if not isinstance(current[key], list):
                return

            # AUTO EXPAND
            while len(current[key]) <= idx:
                current[key].append({})

            if i == len(keys) - 1:
                current[key][idx] = value
            else:
                # FIX: ensure dict
                if current[key][idx] is None:
                    current[key][idx] = {}
                current = current[key][idx]

        else:
            if key not in current:
                return

            if i == len(keys) - 1:
                current[key] = value
            else:
                #  CRITICAL FIX
                if current[key] is None:
                    current[key] = {}
                current = current[key]

def populate(template, row):
    result = copy.deepcopy(template)

    for col, value in row.items():
        if value is None:
            continue

        keys = col.strip().split('.')

        # AUTO HANDLE ROOT (application or not)
        if "application" in result:
            keys = ["application"] + keys

        set_value(result, keys, value)

    return result
