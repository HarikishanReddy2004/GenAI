from utils.logger import get_logger
from utils.config_loader import load_json

logger = get_logger("PolicyExecution")


class PolicyExecution:

    def __init__(self):
        self.execution_table = load_json("config/policy_execution.json")

    def apply(self, policies, data):

        results = []

        for policy in policies:
            code = policy["policyCode"]

            matching_rows = [
                row for row in self.execution_table
                if row["policyCode"] == code
            ]

            selected_row = None

            # Priority match
            for row in matching_rows:
                hv = row.get("highValueInd")
                hs = row.get("highSpendInd")
                mf = row.get("missingAllFicoReasons")

                if hv is not None and hv != data.get("highValueInd"):
                    continue
                if hs is not None and hs != data.get("highSpendInd"):
                    continue
                if mf is not None and mf != data.get("missingAllFicoReasons"):
                    continue

                selected_row = row
                break

            # Fallback match (ALL NULL row)
            if not selected_row:
                for row in matching_rows:
                    if (
                        row.get("highValueInd") is None and
                        row.get("highSpendInd") is None and
                        row.get("missingAllFicoReasons") is None
                    ):
                        selected_row = row
                        break

            if selected_row:
                results.append({
                    **policy,
                    "policyStatus": selected_row["policyStatus"],
                    "policyRank": selected_row["policyRank"],
                    "policyRsnCode": selected_row["policyRsnCode"]
                })

        logger.info(f"PolicyExecution done: {len(results)}")

        return results


from collections import defaultdict


class Deduplication:

    def apply(self, policies):

        grouped = defaultdict(list)

        for p in policies:
            rsn = p.get("policyRsnCode")

            # Ignore None / N/A
            if rsn in [None, "N/A"]:
                p["policyRsnDupInd"] = 0
                continue

            grouped[rsn].append(p)

        for rsn, group in grouped.items():

            # Sort by rank (lower is higher priority)
            group.sort(key=lambda x: x.get("policyRank", 999999))

            for i, policy in enumerate(group):
                if i == 0:
                    policy["policyRsnDupInd"] = 0
                else:
                    policy["policyRsnDupInd"] = 1

        return policies



class Sorting:

    def apply(self, policies):

        return sorted(
            policies,
            key=lambda x: (
                x.get("policyRsnDupInd", 0),
                x.get("policyRank", 999999)
            )
        )



